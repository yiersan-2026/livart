SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=postgres
DB_PASSWORD=

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_LISTENER_CONCURRENCY=3
RABBITMQ_LISTENER_MAX_CONCURRENCY=6
RABBITMQ_LISTENER_PREFETCH=1

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=livartminio
MINIO_SECRET_KEY=livart_minio_change_me
MINIO_BUCKET=livart

JWT_SECRET=dev-only-change-me-livart-jwt-secret-at-least-32-chars
JWT_TTL_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# 可选：填入后，本地新用户会直接使用服务器默认 AI 配置。
LIVART_DEFAULT_API_BASE_URL=
LIVART_DEFAULT_API_KEY=
LIVART_DEFAULT_IMAGE_MODEL=gpt-image-2
LIVART_DEFAULT_CHAT_MODEL=gpt-5.5

# 知识库向量化使用硅基流动 embedding 接口；API Key 必填，缺失或接口失败会直接报错。
LIVART_KNOWLEDGE_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
LIVART_KNOWLEDGE_EMBEDDING_API_KEY=
LIVART_KNOWLEDGE_EMBEDDING_MODEL=BAAI/bge-m3
LIVART_IMAGE_JOB_WORKER_COUNT=16

# 可选：社交媒体图片导入解析接口，只在后端使用，不会下发到浏览器。
LIVART_EXTERNAL_IMAGES_ENDPOINT=https://gogotool.top/api/v1/external/images
LIVART_EXTERNAL_IMAGES_API_KEY=
LIVART_EXTERNAL_IMAGES_TIMEOUT_SECONDS=45
