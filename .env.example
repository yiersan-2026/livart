# 可选配置：不创建本文件也能直接 docker compose up -d --build 启动。
# 如果要公网部署，建议复制为 .env 并替换下面的默认口令。

LIVART_PORT=8080
SPRING_PROFILES_ACTIVE=prod
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
RABBITMQ_DEFAULT_USER=livart
RABBITMQ_DEFAULT_PASS=replace-with-strong-rabbitmq-password
MINIO_ROOT_USER=livartminio
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=livart
JWT_SECRET=replace-with-at-least-32-chars-secret
JWT_TTL_DAYS=30
MINIO_CONSOLE_PORT=9001
LOG_MAX_HISTORY=1
LOG_TOTAL_SIZE_CAP=200MB

# 可选：填入后，新用户首次登录会直接使用服务器默认 AI 配置，不再强制弹出配置框。
LIVART_DEFAULT_API_BASE_URL=
LIVART_DEFAULT_API_KEY=
LIVART_DEFAULT_IMAGE_MODEL=gpt-image-2
LIVART_DEFAULT_CHAT_MODEL=gpt-5.5
