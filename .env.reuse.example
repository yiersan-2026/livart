# 复用已有 PostgreSQL / RabbitMQ / MinIO 时使用。
# 复制为 .env 后，把下面的地址和口令改成你现有 Docker 服务的配置。
# 复用模式不会启动或下载 PostgreSQL、RabbitMQ、MinIO 镜像。

LIVART_PORT=8080

# PostgreSQL：需要已创建数据库，Livart 启动后会自动执行表结构迁移。
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=app
DB_USER=postgres
DB_PASSWORD=replace-with-existing-postgres-password

# RabbitMQ：需要允许 Livart 用户创建队列。
RABBITMQ_HOST=host.docker.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=replace-with-existing-rabbitmq-password

# MinIO：需要允许 Livart 自动创建或使用 MINIO_BUCKET。
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=replace-with-existing-minio-access-key
MINIO_SECRET_KEY=replace-with-existing-minio-secret-key
MINIO_BUCKET=livart

JWT_SECRET=replace-with-at-least-32-chars-secret
JWT_TTL_DAYS=30
LOG_MAX_HISTORY=1
LOG_TOTAL_SIZE_CAP=200MB
